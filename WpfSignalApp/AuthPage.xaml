<Page x:Class="WpfSignalApp.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Auth"
      Background="{DynamicResource ThemePageBg}"
      FontFamily="Segoe UI">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Width="380">

            <!-- Icon + Title -->
            <TextBlock Text="📡" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock x:Name="TbTitle"
                       FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeText}"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock x:Name="TbSubtitle"
                       FontSize="12"
                       Foreground="{DynamicResource ThemeSubText}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap" Margin="0,0,0,24"/>

            <!-- Tab switcher -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnTabLogin" Grid.Column="0"
                        Height="38" FontSize="13" FontWeight="SemiBold"
                        Margin="0,0,4,0"
                        Background="#007ACC"
                        Foreground="White"
                        Click="BtnTabLogin_Click"/>
                <Button x:Name="BtnTabRegister" Grid.Column="1"
                        Height="38" FontSize="13" FontWeight="SemiBold"
                        Margin="4,0,0,0"
                        Background="{DynamicResource ThemeBtnBg}"
                        Foreground="{DynamicResource ThemeBtnFg}"
                        Click="BtnTabRegister_Click"/>
            </Grid>

            <!-- Form card -->
            <Border Background="{DynamicResource ThemeCard}"
                    BorderBrush="{DynamicResource ThemeBorder}"
                    BorderThickness="1.5" CornerRadius="10"
                    Padding="24,20">
                <StackPanel>

                    <!-- Username -->
                    <TextBlock x:Name="TbUsername"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeSubText}"
                               Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtUsername"
                             Height="36" FontSize="13"
                             Background="{DynamicResource ThemeBg}"
                             Foreground="{DynamicResource ThemeText}"
                             BorderBrush="#007ACC" BorderThickness="1"
                             Padding="8,0" VerticalContentAlignment="Center"
                             Margin="0,0,0,12"/>

                    <!-- Email (only for register) -->
                    <StackPanel x:Name="PanelEmail">
                        <TextBlock x:Name="TbEmail"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemeSubText}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtEmail"
                                 Height="36" FontSize="13"
                                 Background="{DynamicResource ThemeBg}"
                                 Foreground="{DynamicResource ThemeText}"
                                 BorderBrush="#007ACC" BorderThickness="1"
                                 Padding="8,0" VerticalContentAlignment="Center"
                                 Margin="0,0,0,12"/>
                    </StackPanel>

                    <!-- Password -->
                    <TextBlock x:Name="TbPassword"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeSubText}"
                               Margin="0,0,0,4"/>
                    <PasswordBox x:Name="TxtPassword"
                                 Height="36" FontSize="13"
                                 Background="{DynamicResource ThemeBg}"
                                 Foreground="{DynamicResource ThemeText}"
                                 BorderBrush="#007ACC" BorderThickness="1"
                                 Padding="8,0"
                                 Margin="0,0,0,16"/>

                    <!-- Submit button -->
                    <Button x:Name="BtnSubmit"
                            Height="42" FontSize="14" FontWeight="Bold"
                            Background="#007ACC" Foreground="White"
                            Click="BtnSubmit_Click"/>

                    <!-- Status message -->
                    <TextBlock x:Name="TbStatus"
                               FontSize="12" TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
