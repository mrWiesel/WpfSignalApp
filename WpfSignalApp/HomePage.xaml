                       FontSize="22" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Оберіть розділ у навігаційній панелі зверху"
                       FontSize="13" Foreground="#d6d6d6"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
