<Page x:Class="WpfSignalApp.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Black" Title="Signal Terminal" FontFamily="Consolas">

    <Page.Resources>
        <Style x:Key="PlusBtn" TargetType="Button">
            <Setter Property="Height"     Value="26"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1e3a1e"/>
            <Setter Property="Margin"     Value="2"/>
            <Setter Property="Padding"    Value="0"/>
        </Style>
        <Style x:Key="MinusBtn" TargetType="Button">
            <Setter Property="Height"     Value="26"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3a1e1e"/>
            <Setter Property="Margin"     Value="2"/>
            <Setter Property="Padding"    Value="0"/>
        </Style>
    </Page.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Polarity ═══ -->
        <Border Grid.Row="0" Grid.Column="0"
                BorderBrush="DarkGray" BorderThickness="2" Margin="2">
            <StackPanel Orientation="Horizontal" Margin="8" VerticalAlignment="Center">

                <Border BorderBrush="#555" BorderThickness="1" CornerRadius="6"
                        Padding="6,8" Margin="0,0,12,0" VerticalAlignment="Center">
                    <StackPanel>
                        <!-- header -->
                        <TextBlock Text="POLARITY  (deg)" Foreground="White" FontSize="10"
                                   HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <!-- + row -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+100°" Width="54" Style="{StaticResource PlusBtn}"  Click="BtnPolPlus100_Click"/>
                            <Button Content="+10°"  Width="48" Style="{StaticResource PlusBtn}"  Click="BtnPolPlus10_Click"/>
                            <Button Content="+1°"   Width="44" Style="{StaticResource PlusBtn}"  Click="BtnPolPlus1_Click"/>
                        </StackPanel>
                        <!-- - row -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Button Content="−1°"   Width="44" Style="{StaticResource MinusBtn}" Click="BtnPolMinus1_Click"/>
                            <Button Content="−10°"  Width="48" Style="{StaticResource MinusBtn}" Click="BtnPolMinus10_Click"/>
                            <Button Content="−100°" Width="54" Style="{StaticResource MinusBtn}" Click="BtnPolMinus100_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Polarity filter:"
                               FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtPolTarget"  Text="Target:  --- deg" Foreground="White"/>
                    <TextBlock x:Name="TxtPolCurrent" Text="Current: 0 deg"   Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ Frequency ═══ -->
        <Border Grid.Row="1" Grid.Column="0"
                BorderBrush="DarkGray" BorderThickness="2" Margin="2">
            <StackPanel Orientation="Horizontal" Margin="8" VerticalAlignment="Center">

                <Border BorderBrush="#555" BorderThickness="1" CornerRadius="6"
                        Padding="6,8" Margin="0,0,12,0" VerticalAlignment="Center">
                    <StackPanel>
                        <!-- header -->
                        <TextBlock Text="FREQUENCY  (MHz)" Foreground="White" FontSize="10"
                                   HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <!-- + row -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+100" Width="54" Style="{StaticResource PlusBtn}"  Click="BtnFreqPlus100_Click"/>
                            <Button Content="+10"  Width="48" Style="{StaticResource PlusBtn}"  Click="BtnFreqPlus10_Click"/>
                            <Button Content="+1"   Width="44" Style="{StaticResource PlusBtn}"  Click="BtnFreqPlus1_Click"/>
                        </StackPanel>
                        <!-- - row -->
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Button Content="−1"   Width="44" Style="{StaticResource MinusBtn}" Click="BtnFreqMinus1_Click"/>
                            <Button Content="−10"  Width="48" Style="{StaticResource MinusBtn}" Click="BtnFreqMinus10_Click"/>
                            <Button Content="−100" Width="54" Style="{StaticResource MinusBtn}" Click="BtnFreqMinus100_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Frequency filter:"
                               FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtFreqTarget"  Text="Target:  --- MHz" Foreground="White"/>
                    <TextBlock x:Name="TxtFreqCurrent" Text="Current: 0 MHz"   Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ Signal status ═══ -->
        <Border Grid.Row="0" Grid.Column="1"
                BorderBrush="DarkGray" BorderThickness="2" Margin="2">
            <TextBlock x:Name="TxtSignalStatus" Text="NO SIGNAL" Foreground="Red"
                       FontSize="34" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- ═══ Stats panel ═══ -->
        <Border Grid.Row="1" Grid.Column="1"
                BorderBrush="DarkGray" BorderThickness="2" Margin="2">
            <StackPanel Margin="10" VerticalAlignment="Center">
                <TextBlock Text="Detector status: Active" Foreground="LimeGreen"/>
                <TextBlock x:Name="TxtObject"  Text="Object: none"       Foreground="White"/>
                <TextBlock x:Name="TxtQuality" Text="Signal quality: 0%" Foreground="White"/>
                <TextBlock Text="Efficiency: 0.000 B\s"       Foreground="Yellow"/>
                <TextBlock Text="Energy consumption: 100.00%" Foreground="DeepSkyBlue"/>
            </StackPanel>
        </Border>

        <!-- ═══ Action buttons ═══ -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="INITIALIZE SCANNER"
                    Width="160" Height="34" Margin="5"
                    Background="#333" Foreground="White"
                    Click="BtnInit_Click"/>
            <Button x:Name="BtnCatch"
                    Content="🎯 ЗЛОВИТИ СИГНАЛ"
                    Width="180" Height="34" Margin="5"
                    Background="lightGreen" Foreground="Purple"
                    FontWeight="Bold" IsEnabled="False"
                    Click="BtnCatch_Click"/>
        </StackPanel>
    </Grid>
</Page>
