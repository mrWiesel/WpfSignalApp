<Page x:Class="WpfSignalApp.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ThemePageBg}"
      FontFamily="Consolas"
      Title="Signal Terminal">

    <Page.Resources>
        <Style x:Key="PlusBtn" TargetType="Button">
            <Setter Property="Height"     Value="26"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeBtnFg}"/>
            <Setter Property="Background" Value="#1e3a1e"/>
            <Setter Property="Margin"     Value="2"/>
            <Setter Property="Padding"    Value="0"/>
        </Style>
        <Style x:Key="MinusBtn" TargetType="Button">
            <Setter Property="Height"     Value="26"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeBtnFg}"/>
            <Setter Property="Background" Value="#3a1e1e"/>
            <Setter Property="Margin"     Value="2"/>
            <Setter Property="Padding"    Value="0"/>
        </Style>
    </Page.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Polarity ═══ -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{DynamicResource ThemeCard}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="2" Margin="2"
                CornerRadius="6">
            <StackPanel Orientation="Horizontal" Margin="8" VerticalAlignment="Center">

                <Border BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" CornerRadius="6"
                        Padding="6,8" Margin="0,0,12,0" VerticalAlignment="Center">
                    <StackPanel>
                        <!-- Локалізований лейбл через Binding -->
                        <TextBlock Text="{Binding PolLabelText}"
                                   Foreground="{DynamicResource ThemeSubText}"
                                   FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+100°" Width="54" Style="{StaticResource PlusBtn}"  Click="BtnPolPlus100_Click"/>
                            <Button Content="+10°"  Width="48" Style="{StaticResource PlusBtn}"  Click="BtnPolPlus10_Click"/>
                            <Button Content="+1°"   Width="44" Style="{StaticResource PlusBtn}"  Click="BtnPolPlus1_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Button Content="−1°"   Width="44" Style="{StaticResource MinusBtn}" Click="BtnPolMinus1_Click"/>
                            <Button Content="−10°"  Width="48" Style="{StaticResource MinusBtn}" Click="BtnPolMinus10_Click"/>
                            <Button Content="−100°" Width="54" Style="{StaticResource MinusBtn}" Click="BtnPolMinus100_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding PolTitleText}"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeText}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding PolTargetText}"  Foreground="{DynamicResource ThemeText}"/>
                    <TextBlock Text="{Binding PolCurrentText}" Foreground="{Binding PolCurrentColor}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ Frequency ═══ -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource ThemeCard}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="2" Margin="2"
                CornerRadius="6">
            <StackPanel Orientation="Horizontal" Margin="8" VerticalAlignment="Center">

                <Border BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="1" CornerRadius="6"
                        Padding="6,8" Margin="0,0,12,0" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{Binding FreqLabelText}"
                                   Foreground="{DynamicResource ThemeSubText}"
                                   FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+100" Width="54" Style="{StaticResource PlusBtn}"  Click="BtnFreqPlus100_Click"/>
                            <Button Content="+10"  Width="48" Style="{StaticResource PlusBtn}"  Click="BtnFreqPlus10_Click"/>
                            <Button Content="+1"   Width="44" Style="{StaticResource PlusBtn}"  Click="BtnFreqPlus1_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Button Content="−1"   Width="44" Style="{StaticResource MinusBtn}" Click="BtnFreqMinus1_Click"/>
                            <Button Content="−10"  Width="48" Style="{StaticResource MinusBtn}" Click="BtnFreqMinus10_Click"/>
                            <Button Content="−100" Width="54" Style="{StaticResource MinusBtn}" Click="BtnFreqMinus100_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding FreqTitleText}"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ThemeText}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding FreqTargetText}"  Foreground="{DynamicResource ThemeText}"/>
                    <TextBlock Text="{Binding FreqCurrentText}" Foreground="{Binding FreqCurrentColor}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ Signal status ═══ -->
        <Border Grid.Row="0" Grid.Column="1"
                Background="{DynamicResource ThemeCard}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="2" Margin="2"
                CornerRadius="6">
            <TextBlock Text="{Binding SignalStatus}"
                       Foreground="{Binding SignalStatusColor}"
                       FontSize="28" FontWeight="Bold"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextWrapping="Wrap" Margin="8"/>
        </Border>

        <!-- ═══ Stats panel ═══ -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="{DynamicResource ThemeCard}"
                BorderBrush="{DynamicResource ThemeBorder}" BorderThickness="2" Margin="2"
                CornerRadius="6">
            <StackPanel Margin="10" VerticalAlignment="Center">
                <TextBlock Text="{Binding DetectorText}"  Foreground="LimeGreen"/>
                <TextBlock Text="{Binding ObjectText}"    Foreground="{DynamicResource ThemeText}"/>
                <TextBlock Text="{Binding QualityText}"   Foreground="{DynamicResource ThemeText}"/>
                <TextBlock Text="{Binding EfficiencyText}" Foreground="Yellow"/>
                <TextBlock Text="{Binding EnergyText}"    Foreground="DeepSkyBlue"/>
            </StackPanel>
        </Border>

        <!-- ═══ Action buttons ═══ -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="{Binding BtnInitText}"
                    Width="180" Height="34" Margin="5"
                    Background="{DynamicResource ThemeBtnBg}"
                    Foreground="{DynamicResource ThemeBtnFg}"
                    Click="BtnInit_Click"/>
            <Button Content="{Binding BtnCatchText}"
                    Width="180" Height="34" Margin="5"
                    Foreground="Black" FontWeight="Bold"
                    IsEnabled="{Binding CatchEnabled}"
                    Click="BtnCatch_Click"/>
        </StackPanel>
    </Grid>
</Page>
