<Page x:Class="WpfSignalApp.SendSignalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Send Signal"
      Background="{DynamicResource ThemePageBg}"
      FontFamily="Consolas">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock x:Name="TbTitle"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource ThemeText}"/>
                <TextBlock x:Name="TbUser"
                           FontSize="11"
                           Foreground="#007ACC"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Button x:Name="BtnLogout" Grid.Column="1"
                    Height="32" Padding="12,0"
                    FontSize="12"
                    Background="#3a1e1e"
                    Foreground="{DynamicResource ThemeBtnFg}"
                    VerticalAlignment="Top"
                    Click="BtnLogout_Click"/>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Autoresponder -->
            <Border Grid.Column="0" Margin="0,0,12,0"
                    Background="{DynamicResource ThemeCard}"
                    BorderBrush="#007ACC" BorderThickness="1.5"
                    CornerRadius="10">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TbAutoresponderLabel"
                               Grid.Row="0"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#007ACC"
                               Margin="0,0,0,10"/>

                    <TextBox x:Name="TxtAutoresponder"
                             Grid.Row="1"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             FontSize="12"
                             FontFamily="Consolas"
                             Background="Transparent"
                             Foreground="{DynamicResource ThemeText}"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             VerticalAlignment="Stretch"/>
                </Grid>
            </Border>

            <!-- Right: Response / Thanks -->
            <Border Grid.Column="1" Margin="12,0,0,0"
                    Background="{DynamicResource ThemeCard}"
                    BorderBrush="{DynamicResource ThemeBorder}"
                    BorderThickness="1.5" CornerRadius="10">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Idle state: animated dots -->
                    <StackPanel x:Name="PanelIdle" Grid.Row="0" Grid.RowSpan="2"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="⬡" FontSize="48"
                                   Foreground="{DynamicResource ThemeSubText}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock x:Name="TbIdleHint"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeSubText}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Countdown panel -->
                    <StackPanel x:Name="PanelCountdown" Grid.Row="0" Grid.RowSpan="2"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Collapsed">
                        <TextBlock Text="📡" FontSize="48"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="TbCountdown"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="#007ACC"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar x:Name="PbCountdown"
                                     Width="180" Height="6"
                                     Minimum="0" Maximum="5"
                                     Value="0"
                                     Foreground="#007ACC"
                                     Background="#333"
                                     Margin="0,12,0,0"/>
                    </StackPanel>

                    <!-- Thanks panel -->
                    <TextBox x:Name="TxtThanks"
                             Grid.Row="0" Grid.RowSpan="2"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             FontSize="12"
                             FontFamily="Consolas"
                             Background="Transparent"
                             Foreground="{DynamicResource ThemeText}"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             Visibility="Collapsed"
                             VerticalAlignment="Stretch"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom: Send button -->
        <Border Grid.Row="2" Margin="0,20,0,0"
                Background="{DynamicResource ThemeCard}"
                BorderBrush="{DynamicResource ThemeBorder}"
                BorderThickness="1.5" CornerRadius="10"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TbIdleHint2"
                           Grid.Column="0"
                           FontSize="12"
                           Foreground="{DynamicResource ThemeSubText}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>

                <Button x:Name="BtnSend"
                        Grid.Column="1"
                        Height="46" Padding="24,0"
                        FontSize="14" FontWeight="Bold"
                        Background="#007ACC"
                        Foreground="White"
                        Click="BtnSend_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
