<Page x:Class="WpfSignalApp.Page4"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White" Title="All Signals">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Всі зловлені сигнали (10 шт.)"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
        <ListBox x:Name="SignalList" Grid.Row="1"/>
    </Grid>
</Page>
