<Page x:Class="WpfSignalApp.Page4"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ThemePageBg}"
      FontFamily="Segoe UI"
      Title="All Signals">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="📡 Всі зловлені сигнали (10 шт.)"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource ThemeText}"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1"
                Background="{DynamicResource ThemeCard}"
                BorderBrush="{DynamicResource ThemeBorder}"
                BorderThickness="1.5" CornerRadius="8">

            <!-- ✅ ItemsSource через Binding — SignalList.ItemsSource = ... більше не потрібен -->
            <!-- ✅ DisplayMemberPath прив'язується до властивості DisplayText моделі SignalData -->
            <ListBox ItemsSource="{Binding Signals}"
                     DisplayMemberPath="DisplayText"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource ThemeText}"
                     FontSize="13"
                     Margin="4">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource ThemeText}"/>
                        <Setter Property="Padding"    Value="8,6"/>
                        <Setter Property="Margin"     Value="0,1"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeBtnBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="DeepSkyBlue"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>
    </Grid>
</Page>
