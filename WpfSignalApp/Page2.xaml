<Page x:Class="WpfSignalApp.Page2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource ThemePageBg}"
      FontFamily="Segoe UI"
      Title="Signal Processing">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">

        <Border Background="{DynamicResource ThemeCard}"
                BorderBrush="{DynamicResource ThemeBorder}"
                BorderThickness="1.5" CornerRadius="10"
                Padding="28,24">
            <StackPanel>
                <!-- Локалізований заголовок -->
                <TextBlock Text="{Binding PageTitle}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource ThemeText}"
                           HorizontalAlignment="Center" Margin="0,0,0,16"/>

                <TextBlock Text="{Binding StatusText}"
                           FontSize="12"
                           Foreground="{DynamicResource ThemeSubText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <ProgressBar Value="{Binding Progress}"
                             Height="22"
                             Minimum="0" Maximum="100"
                             Margin="0,0,0,20"
                             Foreground="DeepSkyBlue"/>

                <!-- Локалізований текст кнопки -->
                <Button Content="{Binding BtnStartText}"
                        Height="40" FontSize="14"
                        IsEnabled="{Binding CanProcess}"
                        Background="{DynamicResource ThemeBtnBg}"
                        Foreground="{DynamicResource ThemeBtnFg}"
                        Click="BtnProcess_Click"/>
            </StackPanel>
        </Border>

    </StackPanel>
</Page>
