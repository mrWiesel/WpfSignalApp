<Page x:Class="WpfSignalApp.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Налаштування"
      Background="{DynamicResource ThemePageBg}"
      FontFamily="Segoe UI">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="360">

            <TextBlock Text="⚙ Налаштування"
                       FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource ThemeText}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>

            <!-- Theme card -->
            <Border Background="{DynamicResource ThemeCard}"
                    BorderBrush="{DynamicResource ThemeBorder}"
                    BorderThickness="1.5" CornerRadius="10"
                    Padding="20,18" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Тема інтерфейсу"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeText}"
                               Margin="0,0,0,14"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ✅ Background через Binding — BtnDark.Background = ... більше не потрібен -->
                        <Button Grid.Column="0"
                                Content="🌙  Темна"
                                Height="42" Margin="0,0,6,0"
                                FontSize="13"
                                Background="{Binding DarkBtnBackground}"
                                Foreground="{DynamicResource ThemeBtnFg}"
                                Click="BtnDark_Click"/>

                        <Button Grid.Column="1"
                                Content="☀  Світла"
                                Height="42" Margin="6,0,0,0"
                                FontSize="13"
                                Background="{Binding LightBtnBackground}"
                                Foreground="{DynamicResource ThemeBtnFg}"
                                Click="BtnLight_Click"/>
                    </Grid>

                    <!-- ✅ Text через Binding -->
                    <TextBlock Text="{Binding CurrentThemeText}"
                               FontSize="11"
                               Foreground="{DynamicResource ThemeSubText}"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Info card -->
            <Border Background="{DynamicResource ThemeCard}"
                    BorderBrush="{DynamicResource ThemeBorder}"
                    BorderThickness="1.5" CornerRadius="10"
                    Padding="20,18">
                <StackPanel>
                    <TextBlock Text="Про програму"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeText}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Mine Radiotelescope app"
                               FontSize="12"
                               Foreground="{DynamicResource ThemeSubText}"
                               TextWrapping="Wrap"/>
                    <TextBlock
                               FontSize="11"
                               Foreground="{DynamicResource ThemeSubText}"
                               Margin="0,4,0,0"><Run Text="Версія 1."/><Run Text="11"/><Run/><Run Text=" "/><Run Text="BETA"/><LineBreak/><Run/></TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </Grid>
</Page>
