<Application x:Class="WpfSignalApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Initial dark-theme values (overwritten at runtime by ThemeManager) -->
        <SolidColorBrush x:Key="ThemeBg"      Color="#0D0D1A"/>
        <SolidColorBrush x:Key="ThemeNavBg"   Color="#1A1A2E"/>
        <SolidColorBrush x:Key="ThemeText"    Color="White"/>
        <SolidColorBrush x:Key="ThemeSubText" Color="#AAAAAA"/>
        <SolidColorBrush x:Key="ThemeCard"    Color="#14142A"/>
        <SolidColorBrush x:Key="ThemeBorder"  Color="DarkGray"/>
        <SolidColorBrush x:Key="ThemeBtnBg"   Color="#333333"/>
        <SolidColorBrush x:Key="ThemeBtnFg"   Color="White"/>
        <SolidColorBrush x:Key="ThemePageBg"  Color="Black"/>
    </Application.Resources>
</Application>
