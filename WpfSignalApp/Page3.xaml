<Page x:Class="WpfSignalApp.Page3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White" Title="Signal Picture">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Image x:Name="MyImage" Grid.Row="0" Stretch="Uniform" Margin="0,0,0,5"/>

        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1">
            <Canvas x:Name="SignalCanvas" Background="Black">
                <Polyline x:Name="waveLine" Stroke="Lime" StrokeThickness="2"/>
            </Canvas>
        </Border>
    </Grid>
</Page>
