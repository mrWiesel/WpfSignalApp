<Window x:Class="WpfSignalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Закарпатська Радіютелескопна Програма"
        Height="550" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Навігаційна панель зверху -->
        <Border Grid.Row="0" Background="#1a1a2e" Padding="10,8">
            <DockPanel>
                <!-- Логотип / назва -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Image Source="radiotelescope.png" Width="36" Height="36" Margin="0,0,8,0" Stretch="Uniform"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ЗРтП" FontSize="18" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Закарпатська Радіютелескопна Програма" FontSize="9" Foreground="#aaa"/>
                    </StackPanel>
                </StackPanel>

                <!-- Кнопки навігації -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="🏠 Головна"        Width="110" Margin="4,0" Padding="6,5" Click="BtnHome_Click"    Tag="Home"/>
                    <Button Content="📡 Зловити сигнал" Width="140" Margin="4,0" Padding="6,5" Click="BtnPage1_Click"   Tag="Page1"/>
                    <Button Content="⚙ Обробка"         Width="110" Margin="4,0" Padding="6,5" Click="BtnPage2_Click"   Tag="Page2"/>
                    <Button Content="📊 Результат"      Width="110" Margin="4,0" Padding="6,5" Click="BtnPage3_Click"   Tag="Page3"/>
                    <Button Content="📋 Всі сигнали"    Width="120" Margin="4,0" Padding="6,5" Click="BtnPage4_Click"   Tag="Page4"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Фрейм для сторінок -->
        <Frame x:Name="MainFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
