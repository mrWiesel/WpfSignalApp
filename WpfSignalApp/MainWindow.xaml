<Window x:Class="WpfSignalApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Закарпатська Радіютелескопна Програма"
        Height="550" Width="860"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemeBg}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Навігаційна панель -->
        <Border Grid.Row="0" Background="{DynamicResource ThemeNavBg}" Padding="10,8">
            <DockPanel>
                <!-- Логотип -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0">
                    <Image Source="radiotelescope.png" Width="36" Height="36"
                           Margin="0,0,8,0" Stretch="Uniform"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ЗРтП" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource ThemeText}"/>
                        <TextBlock Text="Закарпатська Радіютелескопна Програма"
                                   FontSize="9" Foreground="{DynamicResource ThemeSubText}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Settings кнопка праворуч -->
                <Button DockPanel.Dock="Right"
                        Content="⚙" Width="36" Height="36"
                        Margin="4,0" Padding="0"
                        FontSize="18"
                        Background="{DynamicResource ThemeBtnBg}"
                        Foreground="{DynamicResource ThemeBtnFg}"
                        ToolTip="Налаштування"
                        Click="BtnSettings_Click"/>

                <!-- Кнопки навігації -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🏠 Головна"
                            Width="85"  Margin="4,0" Padding="6,5"
                            Background="{DynamicResource ThemeBtnBg}"
                            Foreground="{DynamicResource ThemeBtnFg}"
                            Click="BtnHome_Click"/>
                    <Button Content="📡 Зловити&#xA;сигнал"
                            Width="85"  Margin="4,0" Padding="6,5"
                            Height="46"
                            Background="{DynamicResource ThemeBtnBg}"
                            Foreground="{DynamicResource ThemeBtnFg}"
                            Click="BtnPage1_Click"/>
                    <Button Content="⚙ Обробка"
                            Width="85"  Margin="4,0" Padding="6,5"
                            Background="{DynamicResource ThemeBtnBg}"
                            Foreground="{DynamicResource ThemeBtnFg}"
                            Click="BtnPage2_Click"/>
                    <Button Content="📊 Результат"
                            Width="90"  Margin="4,0" Padding="6,5"
                            Background="{DynamicResource ThemeBtnBg}"
                            Foreground="{DynamicResource ThemeBtnFg}"
                            Click="BtnPage3_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Фрейм -->
        <Frame x:Name="MainFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
